---
const { project } = Astro.props;
---

<div
  class="bg-muted hover:border-accent block rounded-lg border border-transparent p-6 transition-colors"
>
  <h3 class="text-foreground text-xl font-bold">{project.data.title}</h3>
  <p class="text-muted-foreground mt-2">{project.data.headline}</p>
  <div class="mt-4 flex flex-wrap gap-2">
    {
      project.data.stack.map((tag: string) => (
        <span class="bg-background text-muted-foreground rounded-full px-3 py-1 text-sm">
          {tag}
        </span>
      ))
    }
  </div>
</div>
